## Run the rTorrent process as a daemon in the background
# mandatory for XMLRPC since rTorrent 0.9.7
system.daemon.set = true

## control via XMLRPC sockets
#Local UNIX socket
#network.scgi.open_local = (cat,(session.path),rpc.socket)
#execute.nothrow = chmod,770,(cat,(session.path),rpc.socket)

# INET socket — binds to all interfaces for container networking (Flood, etc).
# This port has NO authentication. Do NOT expose it to the host network directly.
# Use Docker/Kubernetes network policies to restrict access.
network.scgi.open_port = 0.0.0.0:16891
